<!-- logback-test.xml for local development, excluded from assembly and version control -->
<configuration>
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{dd.MM.yyyy HH:mm:ss.SSS} %-5level %logger{36} %X{sourceThread} - %msg%n</pattern>
    </encoder>
  </appender>

  <timestamp key="bySecond" datePattern="yyyy-MM-dd--HH-mm-ss"/>

  <root level="warn">
    <appender-ref ref="STDOUT" />
  </root>

  <logger name="com.zaxxer.hikari" level="warn"/>
  <logger name="org.apache.pekko.stream.scaladsl.RestartWithBackoffSource" level="error"/>
  <logger name="wabase.app.BusinessScenariosSpecs" level="info"/>

  <!-- <logger name="org.wabase.tresql" level="debug"/> -->

  <!-- specific route logger, format - <http method>.<uri path with slashes replaced with dots> -->
