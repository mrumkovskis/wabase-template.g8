  <!-- specific view logger -->
  <!-- logger name="purchase_get.get" level="debug"/ -->

  <!-- specific job logger -->
  <!-- logger name="job-name.job" level="debug"/ -->

  <!-- logger name="org.wabase.tresql" level="debug"/ -->

